{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dp1.feralfile.com/schemas/v1.1.0/playlist.json",
  "title": "DP-1 Playlist",
  "description": "A platform-neutral playlist format for distributing, verifying, and preserving blockchain-native digital art (BNDA)",
  "type": "object",
  "required": ["dpVersion", "title", "items"],
  "anyOf": [{ "required": ["signatures"] }, { "required": ["signature"] }],
  "properties": {
    "dpVersion": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "id": { "type": "string", "format": "uuid" },
    "title": { "type": "string", "minLength": 1, "maxLength": 200 },
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "created": { "type": "string", "format": "date-time" },
    "defaults": {
      "type": "object",
      "properties": {
        "display": { "$ref": "#/$defs/DisplayPrefs" },
        "license": { "$ref": "#/$defs/LicenseMode" },
        "duration": { "type": "number", "minimum": 0 }
      }
    },
    "items": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/PlaylistItem" } },
    "signatures": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/Signature" } },
    "signature": { "type": "string", "pattern": "^ed25519:[a-f0-9]+$", "deprecated": true }
  },
  "$defs": {
    "PlaylistItem": {
      "type": "object",
      "required": ["source"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "title": { "type": "string" },
        "source": { "type": "string", "format": "uri" },
        "duration": { "type": "number", "minimum": 0 },
        "license": { "$ref": "#/$defs/LicenseMode" },
        "ref": { "type": "string", "format": "uri" },
        "override": { "type": "object" },
        "display": { "$ref": "#/$defs/DisplayPrefs" },
        "repro": { "$ref": "#/$defs/ReproBlock" },
        "provenance": { "$ref": "#/$defs/ProvenanceBlock" }
      }
    },
    "DisplayPrefs": {
      "type": "object",
      "properties": {
        "scaling": { "type": "string", "enum": ["fit", "fill", "stretch", "auto"] },
        "margin": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "type": "string", "pattern": "^\\d+(\\.\\d+)?(px|%|vw|vh)$" }
          ]
        },
        "background": { "oneOf": [{ "pattern": "^#[0-9a-fA-F]{6}$" }, { "const": "transparent" }] },
        "autoplay": { "type": "boolean" },
        "loop": { "type": "boolean" },
        "interaction": {
          "type": "object",
          "properties": {
            "keyboard": { "type": "array", "items": { "type": "string" } },
            "mouse": {
              "type": "object",
              "properties": {
                "click": { "type": "boolean" },
                "scroll": { "type": "boolean" },
                "drag": { "type": "boolean" },
                "hover": { "type": "boolean" }
              }
            }
          }
        },
        "userOverrides": { "type": "object", "additionalProperties": { "type": "boolean" } }
      }
    },
    "LicenseMode": { "type": "string" },
    "ReproBlock": {
      "type": "object",
      "properties": {
        "engineVersion": { "type": "object", "additionalProperties": { "type": "string" } },
        "seed": { "type": "string" },
        "assetsSHA256": { "type": "array", "items": { "type": "string" } },
        "frameHash": {
          "type": "object",
          "properties": { "sha256": { "type": "string" }, "phash": { "type": "string" } }
        }
      }
    },
    "ProvenanceBlock": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "contract": { "type": "object" },
        "dependencies": { "type": "array", "items": { "type": "object" } }
      }
    },
    "Signature": {
      "type": "object",
      "required": ["alg", "kid", "ts", "payload_hash", "role", "sig"],
      "properties": {
        "alg": { "type": "string", "enum": ["ed25519", "eip191", "ecdsa-secp256k1", "ecdsa-p256"] },
        "kid": { "type": "string", "pattern": "^did:[a-z]+:.+$" },
        "ts": { "type": "string", "format": "date-time" },
        "payload_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "role": {
          "type": "string",
          "enum": ["curator", "feed", "agent", "institution", "licensor"]
        },
        "sig": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" }
      }
    }
  }
}
